@page "/participation"
@using Dong.Application.Crud
@using Dong.Application.Identity
@using Dong.Domain.Entities
@inject ICrud Crud
@inject IIdentity Identity
@rendermode InteractiveServer

<div class="dong-topbar">
    <div>
        <div class="dong-page-title">اعضا</div>
        <div class="dong-page-sub">افزودن دوستان به دورهمی</div>
    </div>
</div>

<div class="dong-content">

    <div class="dong-card">
        <div class="dong-card-header">
            <span class="header-icon">👥</span>
            افزودن عضو جدید
        </div>

        <div class="dong-form-row single">
            <div class="dong-form-group">
                <label>دورهمی</label>
                <div class="dong-select-wrap">
                    <select class="dong-select" @bind="selectedGetTogetherId">
                        <option value="0">انتخاب دورهمی</option>
                        @foreach (var g in getTogethersForOwner)
                        {
                            <option value="@g.Id">@g.NameGetTogether</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="dong-form-row single">
            <div class="dong-form-group">
                <label>شماره موبایل دوست</label>
                <input class="dong-input" placeholder="مثال: 09121234567" @bind="mobile" @bind:event="oninput" />
            </div>
        </div>

        <button class="dong-btn dong-btn-primary" @onclick="SearchAdd">
            👤 &nbsp;اضافه کردن به دورهمی
        </button>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="dong-alert @(message.StartsWith("✅") ? "dong-alert-success" : "dong-alert-danger")">
                @message
            </div>
        }
    </div>

</div>

@code {
    private List<GetTogether> getTogethersForOwner = new();
    private int selectedGetTogetherId;
    private string mobile = string.Empty;
    private string message = string.Empty;

    protected override void OnInitialized()
    {
        getTogethersForOwner = Crud.GetTogethersForOwner(Identity.UserId);
    }

    private void SearchAdd()
    {
        if (selectedGetTogetherId == 0) { message = "❌ لطفاً یک دورهمی انتخاب کنید"; return; }
        if (string.IsNullOrWhiteSpace(mobile)) { message = "❌ لطفاً شماره موبایل را وارد کنید"; return; }

        var user = Crud.FindUserByMobile(mobile);
        if (user == null) { message = $"❌ کاربری با شماره {mobile} پیدا نشد"; return; }

        bool success = Crud.AddParticipations(selectedGetTogetherId, user.Value, out string error);
        if (!success) { message = error; return; }

        message = $"✅ کاربر با شماره {mobile} به دورهمی اضافه شد";
        mobile = string.Empty;
    }
}
