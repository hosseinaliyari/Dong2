@page "/participation"
@using Dong.Application.Crud
@using Dong.Application.Identity
@using Dong.Domain.Entities
@inject ICrud Crud
@inject IIdentity Identity
@rendermode InteractiveServer


<h3>انتخاب دورهمی</h3>
<select class="form-select" @bind="selectedGetTogetherId">
    <option value="0">انتخاب دورهمی</option>
    @foreach (var g in getTogethersForOwner)
    {
        <option value="@g.Id">@g.NameGetTogether</option>
    }
</select>

<h3>اضافه کردن دوستان به دورهمی</h3>
<input class="form-control" placeholder="جستجو با شماره موبایل" @bind="mobile" />

<button class="btn btn-primary mt-2" @onclick="SearchAdd">
    اضافه کن
</button>

<p>@message</p>

@code {
    private List<GetTogether> getTogethersForOwner = new();
    private int selectedGetTogetherId;
    private string mobile = string.Empty;
    private string message = "";

    protected override void OnInitialized()
    {
        int userId = Identity.UserId;

        getTogethersForOwner = Crud.GetTogethersForOwner(userId);
    }

    private void SearchAdd()
    {
        if (selectedGetTogetherId == 0)
        {
            message = "❌ لطفاً یک دورهمی انتخاب کنید";
            return;
        }

        if (string.IsNullOrWhiteSpace(mobile))
        {
            message = "❌ لطفاً شماره موبایل را وارد کنید";
            return;
        }

        // پیدا کردن کاربر
        var user = Crud.FindUserByMobile(mobile);
        if (user == null)
        {
            message = $"❌ کاربری با شماره موبایل {mobile} پیدا نشد";
            return;
        }

        // افزودن Participation
        bool success = Crud.AddParticipations(selectedGetTogetherId, user.Value, out string error);
        if (!success)
        {
            message = error;
            return;
        }

        message = $"✅ کاربر با شماره موبایل {mobile} به دورهمی اضافه شد";
        mobile = string.Empty;
    }
}