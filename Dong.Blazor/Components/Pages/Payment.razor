@page "/payment"
@using Dong.Application.Crud
@using Dong.Application.Identity
@using Dong.Domain.Entities
@inject ICrud Crud
@inject IIdentity Identity
@rendermode InteractiveServer

<div class="dong-topbar">
    <div>
        <div class="dong-page-title">پرداخت</div>
        <div class="dong-page-sub">ثبت پرداخت‌های انجام‌شده بین اعضا</div>
    </div>
</div>

<div class="dong-content">

    <div class="dong-card">
        <div class="dong-card-header">
            <span class="header-icon">💳</span>
            ثبت پرداخت جدید
        </div>

        <div class="dong-form-row single">
            <div class="dong-form-group">
                <label>دورهمی</label>
                <div class="dong-select-wrap">
                    <select class="dong-select" @bind="selectedGetTogetherId" @bind:after="OnGetTogetherChanged">
                        <option value="0">انتخاب دورهمی</option>
                        @foreach (var g in getTogethersForOwner)
                        {
                            <option value="@g.Id">@g.NameGetTogether</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        @if (participations.Any())
        {
            <div class="dong-form-row">
                <div class="dong-form-group">
                    <label>پرداخت‌کننده (بدهکار)</label>
                    <div class="dong-select-wrap">
                        <select class="dong-select" @bind="fromUserId">
                            <option value="0">انتخاب شخص</option>
                            @foreach (var p in participations)
                            {
                                <option value="@p.UserId">@p.User.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="dong-form-group">
                    <label>دریافت‌کننده (بستانکار)</label>
                    <div class="dong-select-wrap">
                        <select class="dong-select" @bind="toUserId">
                            <option value="0">انتخاب شخص</option>
                            @foreach (var p in participations)
                            {
                                <option value="@p.UserId">@p.User.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="dong-form-row single">
                <div class="dong-form-group">
                    <label>مبلغ پرداختی (تومان)</label>
                    <input class="dong-input" type="number" placeholder="0" @bind="amount" />
                </div>
            </div>

            <button class="dong-btn dong-btn-primary" @onclick="SavePayment">
                ✓ &nbsp;ثبت پرداخت
            </button>
        }
        else if (selectedGetTogetherId > 0)
        {
            <div class="dong-alert dong-alert-danger">هیچ عضوی در این دورهمی ثبت نشده</div>
        }

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="dong-alert @(message.StartsWith("✅") ? "dong-alert-success" : "dong-alert-danger")">
                @message
            </div>
        }
    </div>

</div>

@code {
    private List<GetTogether> getTogethersForOwner = new();
    private List<Participation> participations = new();
    private int selectedGetTogetherId;
    private int fromUserId;
    private int toUserId;
    private decimal amount;
    private string message = string.Empty;

    protected override void OnInitialized()
    {
        getTogethersForOwner = Crud.GetTogethersForOwner(Identity.UserId);
    }

    private void OnGetTogetherChanged()
    {
        participations.Clear();
        fromUserId = toUserId = 0;
        if (selectedGetTogetherId > 0)
            participations = Crud.GetParticipationsByGetTogether(selectedGetTogetherId);
    }

    private void SavePayment()
    {
        if (selectedGetTogetherId == 0 || fromUserId == 0 || toUserId == 0)
        { message = "❌ همه فیلدها را کامل کنید"; return; }
        if (fromUserId == toUserId)
        { message = "❌ پرداخت‌کننده و دریافت‌کننده نمی‌توانند یکی باشند"; return; }
        if (amount <= 0)
        { message = "❌ مبلغ نامعتبر است"; return; }

        Crud.AddPayment(fromUserId, toUserId, amount, selectedGetTogetherId);
        message = "✅ پرداخت با موفقیت ثبت شد";
        amount = 0;
        fromUserId = toUserId = 0;
    }
}
