@page "/settlements"
@using Dong.Application.Calculator
@using Dong.Application.Crud
@using Dong.Application.Identity
@using Dong.Domain.Entities
@inject ICrud Crud
@inject IDebitCreditCalculator DebitCreditCalculator
@inject IIdentity Identity
@rendermode InteractiveServer

<div class="dong-topbar">
    <div>
        <div class="dong-page-title">تسویه حساب</div>
        <div class="dong-page-sub">محاسبه بدهی‌ها و تسویه بین اعضا</div>
    </div>
</div>

<div class="dong-content">

    <div class="dong-card">
        <div class="dong-card-header">
            <span class="header-icon">✅</span>
            تسویه حساب دورهمی
        </div>

        <div class="dong-form-row single">
            <div class="dong-form-group">
                <label>دورهمی</label>
                <div class="dong-select-wrap">
                    <select class="dong-select" @bind="selectedGetTogetherId">
                        <option value="0">انتخاب دورهمی</option>
                        @foreach (var g in getTogethersForOwner)
                        {
                            <option value="@g.Id">@g.NameGetTogether</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <button class="dong-btn dong-btn-warning" @onclick="Calculate">
            🔄 &nbsp;محاسبه تسویه
        </button>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="dong-alert @(message.StartsWith("✅") ? "dong-alert-success" : "dong-alert-danger")">
                @message
            </div>
        }
    </div>

    @if (settlements.Any())
    {
        <div class="dong-card">
            <div class="dong-card-header">
                <span class="header-icon">💰</span>
                نتیجه تسویه — چه کسی به چه کسی بدهکار است
            </div>
            <div class="dong-table-wrap">
                <table class="dong-table">
                    <thead>
                        <tr>
                            <th>بدهکار</th>
                            <th>بستانکار</th>
                            <th>مبلغ (تومان)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in settlements)
                        {
                            <tr>
                                <td>
                                    <span class="dong-chip chip-red">@s.FromUserId</span>
                                </td>
                                <td>
                                    <span class="dong-chip chip-green">@s.ToUserId</span>
                                </td>
                                <td class="text-danger">@s.Amount.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@code {
    private List<GetTogether> getTogethersForOwner = new();
    private List<Settlement> settlements = new();
    private int selectedGetTogetherId;
    private string message = string.Empty;

    protected override void OnInitialized()
    {
        getTogethersForOwner = Crud.GetTogethersForOwner(Identity.UserId);
    }

    private void Calculate()
    {
        if (selectedGetTogetherId == 0) { message = "❌ لطفاً یک دورهمی انتخاب کنید"; return; }

        settlements = DebitCreditCalculator.CalculateAndSaveSettlements(selectedGetTogetherId);
        message = "✅ تسویه حساب با موفقیت انجام شد";
    }
}
