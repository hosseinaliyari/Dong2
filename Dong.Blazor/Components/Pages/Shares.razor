@page "/shares"
@using Dong.Application.Calculator
@using Dong.Application.Crud
@using Dong.Application.Identity
@using Dong.Domain.Entities
@inject ICrud Crud
@inject IShareCalculator ShareCalculator
@inject IIdentity Identity
@rendermode InteractiveServer

<div class="dong-topbar">
    <div>
        <div class="dong-page-title">محاسبه سهم</div>
        <div class="dong-page-sub">سهم هر نفر از هزینه‌های مشترک</div>
    </div>
</div>

<div class="dong-content">

    <div class="dong-card">
        <div class="dong-card-header">
            <span class="header-icon">🧮</span>
            محاسبه سهم افراد
        </div>

        <div class="dong-form-row single">
            <div class="dong-form-group">
                <label>دورهمی</label>
                <div class="dong-select-wrap">
                    <select class="dong-select" @bind="selectedGetTogetherId">
                        <option value="0">انتخاب دورهمی</option>
                        @foreach (var g in getTogethersForOwner)
                        {
                            <option value="@g.Id">@g.NameGetTogether</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <button class="dong-btn dong-btn-success" @onclick="Calculate">
            🧮 &nbsp;محاسبه و نمایش
        </button>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="dong-alert @(message.StartsWith("✅") ? "dong-alert-success" : "dong-alert-danger")">
                @message
            </div>
        }
    </div>

    @if (shares.Any())
    {
        <div class="dong-card">
            <div class="dong-card-header">
                <span class="header-icon">📊</span>
                نتیجه محاسبه سهم
            </div>
            <div class="dong-table-wrap">
                <table class="dong-table">
                    <thead>
                        <tr>
                            <th>نام</th>
                            <th>پرداخت کرده (ت)</th>
                            <th>سهم هر نفر (ت)</th>
                            <th>بستانکار / بدهکار (ت)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in shares)
                        {
                            <tr>
                                <td><strong>@s.User?.Name</strong></td>
                                <td>@s.Cost.ToString("N0")</td>
                                <td>@s.PerShare.ToString("N0")</td>
                                <td class="@(s.DebitCredit >= 0 ? "text-success" : "text-danger")">
                                    @(s.DebitCredit >= 0 ? "+" : "")@s.DebitCredit.ToString("N0")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@code {
    private List<GetTogether> getTogethersForOwner = new();
    private List<Share> shares = new();
    private int selectedGetTogetherId;
    private string message = string.Empty;

    protected override void OnInitialized()
    {
        getTogethersForOwner = Crud.GetTogethersForOwner(Identity.UserId);
    }

    private void Calculate()
    {
        if (selectedGetTogetherId == 0) { message = "❌ لطفاً یک دورهمی انتخاب کنید"; return; }

        ShareCalculator.CalculateAndSave(selectedGetTogetherId);
        shares = Crud.GetShare(selectedGetTogetherId);
        message = "✅ محاسبه با موفقیت انجام شد";
    }
}
