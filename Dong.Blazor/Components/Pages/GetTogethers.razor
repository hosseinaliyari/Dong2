@page "/gettogethers"
@using Dong.Application.Crud
@using Dong.Application.Identity
@inject ICrud Crud
@inject IIdentity Identity
@rendermode InteractiveServer

    

@* <h3>ایجاد دورهمی</h3>
<input class="form-control" placeholder="نام دورهمی" @bind="name" />
<br />
<button class="btn btn-primary" @onclick="Create">
    ثبت
</button>
<br />
<p>@message</p> *@


<div class="dong-topbar">
    <div>
        <div class="dong-page-title">دورهمی‌ها</div>
        <div class="dong-page-sub">مدیریت گروه‌های هزینه مشترک</div>
    </div>
</div>

<div class="dong-content">

    <div class="dong-card">
        <div class="dong-card-header">
            <span class="header-icon">➕</span>
            ایجاد دورهمی جدید
        </div>
        <div class="dong-form-row single">
            <div class="dong-form-group">
                <label>نام دورهمی</label>
                <input class="dong-input" placeholder="مثال: شب یلدا، سفر کیش، جشن تولد..." @bind="name" />
            </div>
        </div>
        <button class="dong-btn dong-btn-primary" @onclick="Create">
            ✓ &nbsp;ثبت دورهمی
        </button>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="dong-alert @(message.StartsWith("✅") ? "dong-alert-success" : "dong-alert-danger")">
                @message
            </div>
        }
    </div>

</div>









@code {
    private string name = string.Empty;
    private string message = "";
    private  void Create()
    {
        var userId = Identity.UserId;
        if (string.IsNullOrWhiteSpace(name))
        {
            message = "❌ نام دورهمی را وارد کنید";
            return;
        }

        if (userId <= 0)
        {
            message = "❌ شناسه کاربر معتبر نیست";
            return;
        }
        bool success = Crud.AddGetTogethers(name, userId, out string error);
        if (!success)
        {
            message = error;
            return;
        }
        message = $"دورهمی {name} برای کد کاربری شماره {userId} فعال شد.";
    }
}

