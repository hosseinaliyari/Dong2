@page "/expenses"
@using Dong.Application.Crud
@using Dong.Application.Identity
@using Dong.Domain.Entities
@inject ICrud Crud
@inject IIdentity Identity
@rendermode InteractiveServer

<div class="dong-topbar">
    <div>
        <div class="dong-page-title">هزینه‌ها</div>
        <div class="dong-page-sub">ثبت و مشاهده هزینه‌های دورهمی</div>
    </div>
</div>

<div class="dong-content">

    <div class="dong-card">
        <div class="dong-card-header">
            <span class="header-icon">🧾</span>
            ثبت هزینه جدید
        </div>

        <div class="dong-form-row">
            <div class="dong-form-group">
                <label>دورهمی</label>
                <div class="dong-select-wrap">
                    <select class="dong-select" @bind="selectedGetTogetherId" @bind:after="OnGetTogetherChanged">
                        <option value="0">انتخاب دورهمی</option>
                        @foreach (var g in getTogethersForOwner)
                        {
                            <option value="@g.Id">@g.NameGetTogether</option>
                        }
                    </select>
                </div>
            </div>
            <div class="dong-form-group">
                <label>پرداخت‌کننده</label>
                <div class="dong-select-wrap">
                    <select class="dong-select" @bind="selectedUserId">
                        <option value="0">انتخاب شخص</option>
                        @foreach (var p in participations)
                        {
                            <option value="@p.UserId">@p.User.Name</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="dong-form-row">
            <div class="dong-form-group">
                <label>شرح هزینه</label>
                <input class="dong-input" placeholder="مثال: شام رستوران، بلیت سینما..." @bind="description" />
            </div>
            <div class="dong-form-group">
                <label>مبلغ (تومان)</label>
                <input class="dong-input" type="number" placeholder="0" @bind="cost" />
            </div>
        </div>

        <button class="dong-btn dong-btn-primary" @onclick="Create">
            ✓ &nbsp;ثبت هزینه
        </button>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="dong-alert @(message.StartsWith("✅") ? "dong-alert-success" : "dong-alert-danger")">
                @message
            </div>
        }
    </div>

    @if (participations.Any() && selectedGetTogetherId > 0)
    {
        <div class="dong-card">
            <div class="dong-card-header">
                <span class="header-icon">📋</span>
                هزینه‌های این دورهمی
            </div>
            @{
                var expenses = Crud.GetExpensesByGetTogether(selectedGetTogetherId);
            }
            @if (expenses != null && expenses.Any())
            {
                <div class="dong-table-wrap">
                    <table class="dong-table">
                        <thead>
                            <tr>
                                <th>شرح</th>
                                <th>پرداخت‌کننده</th>
                                <th>مبلغ (تومان)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in expenses)
                            {
                                <tr>
                                    <td>@e.Description</td>
                                    <td>@e.User?.Name</td>
                                    <td class="text-danger">@e.Cost.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="dong-empty">
                    <div class="dong-empty-icon">🧾</div>
                    <p>هنوز هزینه‌ای ثبت نشده</p>
                </div>
            }
        </div>
    }

</div>

@code {
    private List<GetTogether> getTogethersForOwner = new();
    private List<Participation> participations = new();
    private int selectedGetTogetherId;
    private int selectedUserId;
    private string description = string.Empty;
    private decimal cost;
    private string message = string.Empty;

    protected override void OnInitialized()
    {
        getTogethersForOwner = Crud.GetTogethersForOwner(Identity.UserId);
    }

    private void OnGetTogetherChanged()
    {
        participations.Clear();
        if (selectedGetTogetherId > 0)
            participations = Crud.GetParticipationsByGetTogether(selectedGetTogetherId);
    }

    private void Create()
    {
        if (selectedGetTogetherId == 0 || selectedUserId == 0)
        { message = "❌ دورهمی و پرداخت‌کننده را انتخاب کنید"; return; }
        if (string.IsNullOrWhiteSpace(description))
        { message = "❌ شرح هزینه را وارد کنید"; return; }
        if (cost <= 0)
        { message = "❌ مبلغ را وارد کنید"; return; }

        Crud.AddExpense(selectedUserId, description, cost, selectedGetTogetherId);
        message = "✅ هزینه با موفقیت ثبت شد";
        description = string.Empty;
        cost = 0;
        selectedUserId = 0;
    }
}
